# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab

[*.{js,vue,ts,json,yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
# Disable code block validation in markdown
ij_any_language_injections = false
