# ==============================================================================
# smartscan configuration
# Copy to .env and adjust. Everything has a sensible development default;
# values marked CHANGE THIS are required for production.
# ==============================================================================

# --- Application ---
APP_ENV=development                    # development | production
APP_NAME=smartscan                     # Shown in the UI (can be overridden in Admin → Appearance)
SERVER_PORT=8080
FRONTEND_URL=http://localhost:3000     # Public base URL — printed inside QR codes. CHANGE THIS in production!

# --- Database (PostgreSQL 18+) ---
DB_HOST=postgres                       # 'postgres' inside Docker, 'localhost' for local dev
DB_PORT=5432
DB_USER=smartscan
DB_PASSWORD=change-this-in-production  # CHANGE THIS!
DB_NAME=smartscan
DB_SSLMODE=disable                     # disable | require | verify-full — use require+ in production

# --- Redis (queues, rate limiting, token revocation) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth ---
JWT_SECRET=change-me-to-a-random-64-char-string   # CHANGE THIS! min 32 chars in production
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_HOURS=168
INACTIVITY_TIMEOUT_MINUTES=30

# --- Frontend build ---
VITE_API_URL=/api/v1
VITE_APP_NAME=smartscan

# --- QR generation queue ---
QR_GENERATION_ENABLED=true
QR_GENERATION_WORKERS=2
QR_GENERATION_MAX_BATCH_LIMIT=5000000

# --- Optional: server-side reverse geocoding for scan analytics ---
# Get a free key at https://www.bigdatacloud.com — leave empty to disable.
BIGDATACLOUD_API_KEY=

# --- Optional: S3-compatible object storage (falls back to local ./uploads) ---
R2_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Optional: error tracking (Sentry-compatible) ---
SENTRY_DSN=
SENTRY_DEBUG=false

# --- Optional: Prometheus /metrics endpoint basic auth ---
METRICS_USER=
METRICS_PASS=
